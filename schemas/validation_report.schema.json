{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cer/schemas/validation_report.schema.json",
  "title": "CER Validation Report",
  "description": "Schema for reporting validation results for a CER case or artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "case_id",
    "status",
    "findings"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "string",
      "enum": [
        "case",
        "model",
        "document",
        "artifact",
        "rendered_file",
        "package",
        "release"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warning",
        "fail",
        "blocked",
        "waived"
      ]
    },
    "checked_at": {
      "type": "string"
    },
    "validator": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "severity",
          "message"
        ],
        "properties": {
          "finding_id": { "type": "string" },
          "rule_ref": { "type": "string" },
          "failure_mode_ref": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "low",
              "medium",
              "high",
              "critical"
            ]
          },
          "message": { "type": "string" },
          "affected_refs": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "recommended_action": { "type": "string" },
          "state": {
            "type": "string",
            "enum": [
              "open",
              "accepted",
              "repaired",
              "waived",
              "rejected"
            ]
          }
        }
      }
    },
    "release_readiness": {
      "type": "string",
      "enum": [
        "ready",
        "ready_with_waivers",
        "not_ready",
        "unknown"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
